# .env.example — copia esto como ".env" y rellena con tus valores reales.
# El archivo ".env" está en .gitignore y NUNCA debe subirse al repositorio.

# Clave de la API de NASA (DONKI - eventos solares).
# Consíguela gratis en: https://api.nasa.gov/
# Sin esta variable: DEMO_KEY (límite: 30 peticiones/hora, 50/día).
# Con tu propia clave: 1000 peticiones/hora.
EXPO_PUBLIC_NASA_API_KEY=tu_clave_aqui

# Coordenadas de fallback para el índice UV cuando el GPS no está disponible
# (interior, avión, sin permiso). Si no se configuran, se usan las coordenadas
# por defecto de Chipiona, Cádiz (zona del autor del proyecto).
EXPO_PUBLIC_LAT=36.74
EXPO_PUBLIC_LON=-6.43
